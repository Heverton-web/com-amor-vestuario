# =============================================================================
# VARIÁVEIS DE AMBIENTE - EXEMPLO
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores
# =============================================================================

# =============================================================================
# SUPABASE - Banco de Dados e Autenticação
# =============================================================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# APLICATIVO
# =============================================================================
VITE_APP_URL=https://comamor.com.br
NODE_ENV=production

# =============================================================================
# MERCADO PAGO (PENDENTE - Feature Pagamentos)
# =============================================================================
# MP_ACCESS_TOKEN=APP_TEST_xxxxx...
# MP_PUBLIC_KEY=APP_TEST_xxxxx...
# MP_WEBHOOK_SECRET=xxxxx...

# =============================================================================
# N8N - Automação
# =============================================================================
N8N_HOST=n8n.comamor.com.br
N8N_PORT=5678
N8N_PROTOCOL=https

# =============================================================================
# LISTMONK - E-mail Marketing
# =============================================================================
LISTMONK_URL=http://listmonk:9000
LISTMONK_API_KEY=xxxxx...
LISTMONK_LIST_ID=1

# =============================================================================
# EVOLUTION API - WhatsApp
# =============================================================================
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=xxxxx...

# =============================================================================
# DATABASE - PostgreSQL (ListMonk + Evolution)
# =============================================================================
LISTMONK_DB_PASSWORD=xxxxx...
LISTMONK_DB_HOST=postgres
LISTMONK_DB_PORT=5432
LISTMONK_DB_NAME=listmonk
LISTMONK_DB_USER=listmonk

EVOLUTION_DB_PASSWORD=xxxxx...
EVOLUTION_DB_HOST=postgres
EVOLUTION_DB_PORT=5432
EVOLUTION_DB_NAME=evolution

# =============================================================================
# WEBHOOK
# =============================================================================
WEBHOOK_URL=https://n8n.comamor.com.br/webhook

# =============================================================================
# GERAR SENHAS SEGURAS
# =============================================================================
# Use os comandos abaixo para gerar senhas aleatórias:
#
# Linux/Mac:
#   openssl rand -hex 32  (para API keys)
#   openssl rand -hex 16  (para senhas banco)
#
# PowerShell:
#   [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes(16) | ForEach-Object { $_.ToString("x2") }
#
# =============================================================================
# INSTRUÇÕES
# =============================================================================
# 1. Copie este arquivo para .env
# 2. Preencha todos os valores
# 3. Para desenvolvimento local, crie .env.local (não versionado)
# 4. Para produção (VPS), use o mesmo arquivo .env
# 5. NUNCA versione arquivos com senhas reais!